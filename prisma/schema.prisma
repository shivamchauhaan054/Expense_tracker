generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Expense {
  id             String   @id @default(cuid())
  // Store money as smallest unit (e.g. paise/cents) to avoid floating-point errors.
  amount         Int
  category       String
  description    String?
  date           DateTime
  createdAt      DateTime @default(now())
  idempotencyKey String   @unique

  @@index([date])
  @@index([category])
}
